*.tfvars
*~
bin/
build/
Dockerfile.pip
node_modules/
obj/
pkg/
release/wi-kubernetes-manifests.yaml
vendor/

# MODIFIED: Generated by vagrant/ansible-ssh-env.sh (local Vagrant SSH key path)
vagrant/.ansible-ssh-env.generated

# --- MODIFIED: On-prem / local secrets & generated artifacts (do not push) ---
# K3s / kubectl: fetched by Ansible (contains client certs + private keys)
k3s-kubeconfig
**/k3s-kubeconfig
kubeconfig
*.kubeconfig

# Environment and cloud credential files
.env
.env.*
!.env.example
credentials.json
*-credentials.json
service-account*.json
gcp-*.json
application_default_credentials.json

# TLS / SSH material (common leak vectors)
*.pem
*.p12
*.pfx
id_rsa
id_ed25519
*_rsa
*_ed25519

# Generated kustomize / build output
kustomize.out
*.generated.yaml

# Vagrant VM state (large, host-specific, may include paths/metadata)
.vagrant/
vagrant/.vagrant/

# Ansible local cache & transient
.ansible/
*.retry

# Logs and OS junk
*.log
Thumbs.db
Desktop.ini

# Python
__pycache__/
*.py[cod]
